{
  "name": "claude-better-usage",
  "publisher": "ijuani",
  "displayName": "Claude Code - Better Usage",
  "description": "Shows Claude Code usage (rate limits) in the status bar + real-time background agent monitoring panel",
  "icon": "favicon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IJuanI/claude-usage-bar"
  },
  "version": "0.5.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsageBar.refresh",
        "title": "Claude Usage Bar: Refresh"
      },
      {
        "command": "claudeUsageBar.openPanel",
        "title": "Claude Usage Bar: Open Panel"
      },
      {
        "command": "claudeUsageBar.toggleDebug",
        "title": "Claude Agents: Toggle Debug Mode"
      },
      {
        "command": "claudeUsageBar.copyDebugInfo",
        "title": "Claude Agents: Copy Workspace & Session"
      },
      {
        "command": "claudeUsageBar.openAgents",
        "title": "Background Agents",
        "icon": {
          "light": "media/agents-icon-light.svg",
          "dark": "media/agents-icon.svg"
        }
      },
      {
        "command": "claudeUsageBar.searchSessions",
        "title": "Claude Sessions: Search",
        "icon": "$(search)"
      },
      {
        "command": "claudeUsageBar.clearSessionSearch",
        "title": "Claude Sessions: Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudeUsageBar.refreshSessions",
        "title": "Claude Sessions: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeUsageBar.deepSearch",
        "title": "Claude Sessions: Deep Search (content)"
      },
      {
        "command": "claudeUsageBar.copySessionId",
        "title": "Copy Session ID"
      },
      {
        "command": "claudeUsageBar.copyAgentId",
        "title": "Copy Agent ID"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claudeUsageBar.openAgents",
          "when": "claudeUsageBar.hasBackgroundAgents && activeWebviewPanelId == claudeVSCodePanel",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "claudeUsageBar.searchSessions",
          "when": "view == claudeUsageBar.sessionTree",
          "group": "navigation@1"
        },
        {
          "command": "claudeUsageBar.clearSessionSearch",
          "when": "view == claudeUsageBar.sessionTree && claudeUsageBar.sessionSearchActive",
          "group": "navigation@2"
        },
        {
          "command": "claudeUsageBar.refreshSessions",
          "when": "view == claudeUsageBar.sessionTree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeUsageBar.copySessionId",
          "when": "viewItem == session",
          "group": "inline"
        },
        {
          "command": "claudeUsageBar.copyAgentId",
          "when": "viewItem == agent",
          "group": "inline"
        }
      ]
    },
    "views": {
      "claude-sessions-sidebar": [
        {
          "id": "claudeUsageBar.sessionTree",
          "name": "Sessions"
        },
        {
          "type": "webview",
          "id": "claudeUsageBar.agentView",
          "name": "Background Agents"
        },
        {
          "type": "webview",
          "id": "claudeUsageBar.usageView",
          "name": "Claude Usage"
        }
      ]
    },
    "configuration": {
      "title": "Claude Usage Bar",
      "properties": {
        "claudeUsageBar.refreshInterval": {
          "type": "number",
          "default": 60,
          "description": "How often to refresh usage data (seconds)"
        },
        "claudeUsageBar.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Show debug toolbar in Claude Agents panel (workspace/session selectors)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
